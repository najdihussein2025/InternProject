@{
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewBag.PageTitle = "Progress";
}
<section class="student-panel progress-main">
    <h3>Overall Progress</h3>
    <div class="student-progress-lg">
        <i style="--w:72%"></i>
        <span>72%</span>
    </div>
    <div class="student-cards compact">
        <article class="student-card"><p>Completed Tasks</p><h3>18</h3></article>
        <article class="student-card"><p>Completed Projects</p><h3>4</h3></article>
        <article class="student-card"><p>Remaining Work</p><h3>7</h3></article>
    </div>
</section>

<section class="student-panel">
    <h3>Performance Charts</h3>
    <div class="student-bars">
        <div><span>Tasks</span><i style="--w:78%"></i></div>
        <div><span>Projects</span><i style="--w:66%"></i></div>
        <div><span>Final Project</span><i style="--w:52%"></i></div>
    </div>
</section>

<section class="student-panel">
    <h3>Learning Timeline</h3>
    <ul class="student-timeline">
        <li><span>Month 1</span><p>Core fundamentals completed and first sprint submitted.</p></li>
        <li><span>Month 2</span><p>API integration and dashboard modules in progress.</p></li>
        <li><span>Month 3</span><p>Advanced tasks scheduled with project hardening phase.</p></li>
        <li><span>Final Project</span><p>Capstone planning submitted, implementation phase started.</p></li>
    </ul>
</section>
