@{
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewBag.PageTitle = "Dashboard";
}
<section class="student-welcome">
    <h2>Welcome back, Sara 👋</h2>
    <p>Stay on track with your major milestones, tasks, and final project delivery.</p>
</section>

<section class="student-cards">
    <article class="student-card"><p>Current Major</p><h3>Web Development</h3></article>
    <article class="student-card"><p>Month Progress</p><h3>Month 2 / 3</h3><div class="student-progress"><i style="--w:66%"></i></div></article>
    <article class="student-card"><p>KPI: Task Completion</p><h3>18 / 25</h3></article>
    <article class="student-card"><p>KPI: Project Score</p><h3>84%</h3></article>
</section>

<section class="student-grid-two">
    <article class="student-panel">
        <h3>Upcoming Deadlines</h3>
        <ul class="student-list">
            <li><span>Responsive UI Assignment</span><b class="badge pending">Due May 08</b></li>
            <li><span>REST API Integration Task</span><b class="badge pending">Due May 12</b></li>
            <li><span>Team Project Sprint Demo</span><b class="badge pending">Due May 18</b></li>
            <li><span>Final Project Proposal</span><b class="badge pending">Due May 24</b></li>
        </ul>
    </article>
    <article class="student-panel">
        <h3>Quick Actions</h3>
        <div class="student-actions">
            <a href="@Url.Action("Tasks", "Student")">Open My Tasks</a>
            <a href="@Url.Action("Projects", "Student")">Open Projects</a>
            <a href="@Url.Action("FinalProject", "Student")">View Final Project</a>
            <a href="@Url.Action("Progress", "Student")">Track Progress</a>
        </div>
    </article>
</section>
