@{
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewBag.PageTitle = "Courses";
}
<section class="student-course-grid">
    <article class="student-panel">
        <h3>ASP.NET Core Fundamentals</h3>
        <p>Routing, controllers, views, and middleware essentials.</p>
        <div class="student-progress"><i style="--w:70%"></i></div>
        <button class="student-btn primary">Continue</button>
    </article>
    <article class="student-panel">
        <h3>Frontend Architecture</h3>
        <p>Reusable components, accessibility, and dashboard UI patterns.</p>
        <div class="student-progress"><i style="--w:52%"></i></div>
        <button class="student-btn primary">Continue</button>
    </article>
    <article class="student-panel">
        <h3>Database Design Basics</h3>
        <p>Schema planning, relationships, and SQL query fundamentals.</p>
        <div class="student-progress"><i style="--w:81%"></i></div>
        <button class="student-btn primary">Continue</button>
    </article>
    <article class="student-panel">
        <h3>Team Collaboration</h3>
        <p>Version control workflows and communication best practices.</p>
        <div class="student-progress"><i style="--w:44%"></i></div>
        <button class="student-btn primary">Continue</button>
    </article>
</section>
