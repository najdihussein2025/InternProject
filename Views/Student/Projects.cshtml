@{
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewBag.PageTitle = "Projects";
}
<section class="student-project-grid">
    <article class="student-panel">
        <h3>E-Commerce Frontend</h3>
        <p>Design and implement product listing pages and cart components.</p>
        <span class="badge pending">In Progress</span>
        <div class="student-actions-row"><button class="student-btn">View Details</button><button class="student-btn primary">Submit Work</button></div>
    </article>
    <article class="student-panel">
        <h3>Analytics Dashboard</h3>
        <p>Build charts, card widgets, and filter interactions for intern stats.</p>
        <span class="badge done">Completed</span>
        <div class="student-actions-row"><button class="student-btn">View Details</button><button class="student-btn primary">Submit Work</button></div>
    </article>
    <article class="student-panel">
        <h3>Task Tracker App</h3>
        <p>Create a kanban-style board for team task updates and statuses.</p>
        <span class="badge pending">Pending Review</span>
        <div class="student-actions-row"><button class="student-btn">View Details</button><button class="student-btn primary">Submit Work</button></div>
    </article>
</section>
