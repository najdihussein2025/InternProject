@{
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewBag.PageTitle = "Projects";
}
<section class="student-project-grid">
    <article class="student-panel">
        <h3>Sprint Project: E-Commerce Frontend</h3>
        <p>Design and implement product listing pages and cart components with responsive behavior.</p>
        <span class="badge pending">In Progress</span>
        <div class="student-actions-row"><button class="student-btn">View Details</button><button class="student-btn primary">Submit Work</button></div>
    </article>
    <article class="student-panel">
        <h3>Sprint Project: Analytics Dashboard</h3>
        <p>Build charts, KPI cards, and filter interactions for internship performance metrics.</p>
        <span class="badge done">Completed</span>
        <div class="student-actions-row"><button class="student-btn">View Details</button><button class="student-btn primary">Submit Work</button></div>
    </article>
    <article class="student-panel">
        <h3>Sprint Project: Task Tracker App</h3>
        <p>Create a kanban-style board for team task updates, priorities, and status tracking.</p>
        <span class="badge pending">Pending Review</span>
        <div class="student-actions-row"><button class="student-btn">View Details</button><button class="student-btn primary">Submit Work</button></div>
    </article>
</section>
