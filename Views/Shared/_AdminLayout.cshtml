@{
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var pageTitle = ViewBag.PageTitle as string ?? "Admin";
    var adminName = ViewBag.AdminName as string ?? "Admin User";
    var pendingCount = Convert.ToInt32(ViewBag.PendingCount ?? 0);
    var unreadCount = Convert.ToInt32(ViewBag.UnreadCount ?? 0);
    var initials = string.Join(string.Empty, adminName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpperInvariant();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - InternHub Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=JetBrains+Mono:wght@400;600&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InternSystemProject.styles.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="sidebar-overlay" data-sidebar-overlay></div>
    <div class="admin-shell">
        <aside class="sidebar" id="adminSidebar" aria-label="Admin Navigation">
            <div class="sidebar-brand-wrap">
                <a class="sidebar-brand" href="@Url.Action("Dashboard", "Admin")">
                    <span class="sidebar-brand-icon">IH</span>
                    <span class="sidebar-brand-text">InternHub</span>
                </a>
                <span class="sidebar-badge">Admin Panel</span>
            </div>

            <nav class="sidebar-nav">
                <p class="sidebar-group-title">Dashboard</p>
                <a class="sidebar-link @(currentAction == "dashboard" ? "active" : string.Empty)" data-nav-link href="@Url.Action("Dashboard", "Admin")">
                    <span class="sidebar-link-icon"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="8" height="8" rx="2" /><rect x="13" y="3" width="8" height="5" rx="2" /><rect x="13" y="10" width="8" height="11" rx="2" /><rect x="3" y="13" width="8" height="8" rx="2" /></svg></span>
                    <span>Dashboard</span>
                </a>

                <p class="sidebar-group-title">Recruitment</p>
                <a class="sidebar-link @(currentAction == "applications" ? "active" : string.Empty)" data-nav-link href="@Url.Action("Applications", "Admin")">
                    <span class="sidebar-link-icon"><svg viewBox="0 0 24 24" fill="none"><rect x="5" y="3" width="14" height="18" rx="2" /><path d="M9 8h6M9 12h6M9 16h4" /></svg></span>
                    <span>Applications</span>
                    @if (pendingCount > 0)
                    {
                        <span class="nav-count">@pendingCount</span>
                    }
                </a>
                <a class="sidebar-link @(currentAction == "acceptedinterns" ? "active" : string.Empty)" data-nav-link href="@Url.Action("AcceptedInterns", "Admin")">
                    <span class="sidebar-link-icon"><svg viewBox="0 0 24 24" fill="none"><circle cx="8" cy="8" r="3.2" /><circle cx="16.4" cy="9" r="2.6" /><path d="M3 19c0-3 2.6-5 5.8-5 3.1 0 5.7 2 5.7 5" /><path d="M13 19c0-2.2 1.8-3.8 4.1-3.8 2.2 0 3.9 1.6 3.9 3.8" /></svg></span>
                    <span>Accepted Interns</span>
                </a>
                <a class="sidebar-link @(currentAction == "archived" ? "active" : string.Empty)" data-nav-link href="@Url.Action("Archived", "Admin")">
                    <span class="sidebar-link-icon"><svg viewBox="0 0 24 24" fill="none"><rect x="4" y="5" width="16" height="14" rx="2" /><path d="M4 9h16M9 13h6" /></svg></span>
                    <span>Archived</span>
                </a>
                <a class="sidebar-link @((currentAction == "users" || currentAction == "userdetails") ? "active" : string.Empty)" data-nav-link href="@Url.Action("Users", "Admin")">
                    <span class="sidebar-link-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M7 8a3 3 0 1 0 0 6 3 3 0 0 0 0-6zM17 7a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5z" /><path d="M2.5 19c0-2.8 2.4-4.8 5.4-4.8s5.3 2 5.3 4.8M12.5 19c0-2.2 1.9-3.8 4.4-3.8 2.4 0 4.1 1.6 4.1 3.8" /></svg></span>
                    <span>Users</span>
                </a>

                <p class="sidebar-group-title">Programs</p>
                <a class="sidebar-link @((currentAction == "majors" || currentAction == "majordetails" || currentAction == "majorinterns") ? "active" : string.Empty)" data-nav-link href="@Url.Action("Majors", "Admin")">
                    <span class="sidebar-link-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M4 6h16v12H4z" /><path d="M8 10h8M8 14h6" /></svg></span>
                    <span>Majors</span>
                </a>
                <a class="sidebar-link @(currentAction == "tasks" ? "active" : string.Empty)" data-nav-link href="@Url.Action("Tasks", "Admin")">
                    <span class="sidebar-link-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M8 7h12M8 12h12M8 17h12" /><path d="M4 7h.01M4 12h.01M4 17h.01" /></svg></span>
                    <span>Tasks</span>
                </a>
                <a class="sidebar-link @(currentAction == "finalprojects" ? "active" : string.Empty)" data-nav-link href="@Url.Action("FinalProjects", "Admin")">
                    <span class="sidebar-link-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M4 18V6l8 4 8-4v12l-8 4z" /><path d="M12 10v12" /></svg></span>
                    <span>Final Projects</span>
                </a>

                <p class="sidebar-group-title">Performance</p>
                <a class="sidebar-link @(currentAction == "progresstracking" ? "active" : string.Empty)" data-nav-link href="@Url.Action("ProgressTracking", "Admin")">
                    <span class="sidebar-link-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M4 19h16" /><path d="M7 15l3-3 3 2 4-5" /><circle cx="7" cy="15" r="1" /><circle cx="10" cy="12" r="1" /><circle cx="13" cy="14" r="1" /><circle cx="17" cy="9" r="1" /></svg></span>
                    <span>Progress Tracking</span>
                </a>
                <a class="sidebar-link @(currentAction == "reports" ? "active" : string.Empty)" data-nav-link href="@Url.Action("Reports", "Admin")">
                    <span class="sidebar-link-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M4 20V9M10 20V4M16 20v-8M22 20v-5" /></svg></span>
                    <span>Reports</span>
                </a>

                <p class="sidebar-group-title">System</p>
                <a class="sidebar-link @(currentAction == "settings" ? "active" : string.Empty)" data-nav-link href="@Url.Action("Settings", "Admin")">
                    <span class="sidebar-link-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z" /><path d="M3 12h2m14 0h2M12 3v2m0 14v2M5.6 5.6l1.4 1.4m10 10 1.4 1.4M18.4 5.6 17 7m-10 10-1.4 1.4" /></svg></span>
                    <span>Settings</span>
                </a>
            </nav>

            <div class="sidebar-profile">
                <span class="avatar-circle">@initials</span>
                <div>
                    <p>@adminName</p>
                    <small>Administrator</small>
                </div>
                <a class="logout-link" href="@Url.Action("Logout", "Auth")" title="Logout">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M9 4H5v16h4" /><path d="M14 8l4 4-4 4" /><path d="M18 12H9" /></svg>
                </a>
            </div>
        </aside>

        <div class="admin-main">
            <header class="topbar">
                <div class="topbar-left">
                    <button class="icon-btn topbar-menu" type="button" aria-controls="adminSidebar" aria-label="Toggle sidebar" data-sidebar-toggle>
                        <span></span><span></span><span></span>
                    </button>
                    <div>
                        <h1>@pageTitle</h1>
                        <p>Admin / @pageTitle</p>
                    </div>
                </div>
                <div class="topbar-right">
                    <label class="top-search">
                        <input type="search" placeholder="Search..." />
                    </label>
                    <a class="icon-btn" href="@Url.Action("Notifications", "Admin")" aria-label="Notifications">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M12 3a5 5 0 0 0-5 5v2.5L5 14v1h14v-1l-2-3.5V8a5 5 0 0 0-5-5z" /><path d="M10 18a2 2 0 0 0 4 0" /></svg>
                        @if (unreadCount > 0)
                        {
                            <span class="dot-alert"></span>
                        }
                    </a>
                    <div class="top-avatar-menu" data-dropdown>
                        <button class="avatar-btn" type="button" aria-haspopup="true" aria-expanded="false">@initials</button>
                        <div class="avatar-dropdown">
                            <a href="@Url.Action("Settings", "Admin")">My Settings</a>
                            <a href="@Url.Action("Logout", "Auth")">Logout</a>
                        </div>
                    </div>
                </div>
            </header>

            @if (TempData["Success"] != null || TempData["Error"] != null)
            {
                <div class="admin-alert @(TempData["Error"] != null ? "error" : "success")" data-alert>
                    <span>@(TempData["Error"] ?? TempData["Success"])</span>
                    <button type="button" aria-label="Dismiss alert" data-alert-dismiss>&times;</button>
                </div>
            }

            <main class="content-area">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/js/admin.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
