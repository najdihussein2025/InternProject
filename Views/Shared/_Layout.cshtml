<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InternHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=JetBrains+Mono:wght@400;600&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/public.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InternSystemProject.styles.css" asp-append-version="true" />
</head>
<body class="public-layout">
    <header>
        <nav class="public-nav">
            <div class="public-nav-inner">
                <a class="public-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="public-brand-icon">IH</span>
                    <span>InternHub</span>
                </a>
                <div class="public-nav-links">
                    <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    <a asp-area="" asp-controller="Home" asp-action="About">About Us</a>
                    <a asp-area="" asp-controller="Home" asp-action="Contact">Contact Us</a>
                </div>
                <div class="public-nav-actions">
                    <a class="public-btn public-btn-ghost" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
                    <a class="public-btn public-btn-cyan" asp-area="" asp-controller="Account" asp-action="Signup">Sign Up</a>
                </div>
            </div>
        </nav>
    </header>
    <div class="public-shell">
        <main role="main" class="public-main">
            @RenderBody()
        </main>
    </div>

    <footer class="public-footer">
        <div class="public-footer-inner">
            <span>&copy; 2026 InternHub. All rights reserved.</span>
            <span>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </span>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
