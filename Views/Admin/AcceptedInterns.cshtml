@model IEnumerable<InternSystemProject.DTOs.User.UserDto>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.PageTitle = "Accepted Interns";
}

<section class="page-toolbar">
    <h2>Accepted Interns <span class="pill green-soft">@(Model?.Count() ?? 0)</span></h2>
    <div class="toolbar-actions">
        <input type="search" placeholder="Search accepted interns..." />
        <select><option>All Majors</option><option>Web Dev</option><option>AI</option><option>Security</option><option>Data</option></select>
        <button class="btn ghost" type="button">Export CSV</button>
    </div>
</section>

<div class="table-wrap">
    <table class="admin-table">
        <thead>
            <tr><th>#</th><th>Name</th><th>Email</th><th>Major</th><th>Status</th><th>Progress</th><th>Joined</th><th>Actions</th></tr>
        </thead>
        <tbody>
        @foreach (var user in Model ?? Enumerable.Empty<InternSystemProject.DTOs.User.UserDto>())
        {
            <tr><td>@user.Id</td><td>@user.FullName</td><td>@user.Email</td><td>@user.Major</td><td>@user.Status</td><td>@user.Progress</td><td>@user.Joined</td><td class="actions"><a href="@Url.Action("UserDetails","Admin", new { id = user.Id })">👁</a></td></tr>
        }
        </tbody>
    </table>
</div>
