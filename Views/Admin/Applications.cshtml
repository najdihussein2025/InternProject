@model List<InternSystemProject.DTOs.User.UserDto>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.PageTitle = "Applications";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error">@TempData["Error"]</div>
}

<section class="page-toolbar">
    <h2>Pending Applications <span class="pill amber-soft">@Model.Count</span></h2>
    <p>Review and approve or reject intern applications.</p>
</section>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <p>No pending applications at the moment.</p>
    </div>
}
else
{
    <section class="card">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Applied Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@user.Joined.ToString("MMM dd, yyyy")</td>
                        <td>
                            <form asp-action="ApproveUser" asp-controller="Admin"
                                  method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit" class="btn-approve"
                                        onclick="return confirm('Approve this intern?')">
                                    ✓ Approve
                                </button>
                            </form>

                            <form asp-action="RejectUser" asp-controller="Admin"
                                  method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit" class="btn-reject"
                                        onclick="return confirm('Reject this intern?')">
                                    ✗ Reject
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

<style>
    .btn-approve {
        background-color: #16a34a;
        color: #fff;
        border: none;
        padding: 6px 10px;
        border-radius: 6px;
        cursor: pointer;
    }

    .btn-reject {
        background-color: #dc2626;
        color: #fff;
        border: none;
        padding: 6px 10px;
        border-radius: 6px;
        cursor: pointer;
    }
</style>
