@model IEnumerable<InternSystemProject.DTOs.User.UserDto>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.PageTitle = "Users";
}
@{
    var users = Model ?? Enumerable.Empty<InternSystemProject.DTOs.User.UserDto>();
    var searchTerm = ViewBag.SearchTerm as string ?? string.Empty;
}
<section class="page-toolbar">
    <div>
        <h2>All Interns <span class="pill cyan-soft">@users.Count()</span></h2>
    </div>
    <div class="toolbar-actions">
        <form method="get" action="@Url.Action("Users", "Admin")" id="usersSearchForm">
            <input type="search" id="usersSearchInput" name="name" value="@searchTerm" placeholder="Search interns..." />
        </form>
        <select><option>All Majors</option><option>Web Dev</option><option>AI</option><option>Security</option><option>Data</option></select>
        <button class="btn ghost" type="button">Export CSV</button>
        <button class="btn primary-add" type="button" data-open-modal="addUserModal"><span class="plus-icon">+</span> Add User</button>
    </div>
</section>

<div class="filter-tabs" data-filter-tabs="users">
    <button class="active" data-filter="all">All</button>
    <button data-filter="active">Active</button>
    <button data-filter="pending">Pending</button>
    <button data-filter="rejected">Rejected</button>
    <button data-filter="completed">Completed</button>
</div>

@section Scripts {
    <script>
        (() => {
            const form = document.getElementById("usersSearchForm");
            const input = document.getElementById("usersSearchInput");
            if (!form || !input) return;

            let timerId = null;
            input.addEventListener("input", () => {
                if (timerId) clearTimeout(timerId);
                timerId = setTimeout(() => form.submit(), 350);
            });
        })();
    </script>
}

<div class="table-wrap">
    <table class="admin-table" data-users-table>
        <thead>
            <tr><th><input type="checkbox" /></th><th>#</th><th>Name</th><th>Email</th><th>Major</th><th>Status</th><th>Progress</th><th>Join Date</th><th>Actions</th></tr>
        </thead>
        <tbody>
        @foreach (var user in users)
        {
            var initials = new string(
                user.FullName
                    .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                    .Take(2)
                    .Select(part => char.ToUpperInvariant(part[0]))
                    .ToArray()
            );

            <tr data-status="@user.Status.ToLowerInvariant()">
                <td><input type="checkbox" /></td>
                <td>@user.Id</td>
                <td>
                    <div class="name-cell">
                        <span class="mini-avatar web">@initials</span>
                        <strong>@user.FullName</strong>
                    </div>
                </td>
                <td>@user.Email</td>
                <td><span class="pill cyan-soft">@(string.IsNullOrWhiteSpace(user.Major) ? "Unassigned" : user.Major)</span></td>
                <td><span class="pill green-soft">@user.Status</span></td>
                <td><div class="progress-line web"><i style="--w:@user.Progress%"></i></div>@user.Progress%</td>
                <td>@user.Joined.ToString("MMM dd, yyyy")</td>
                <td class="actions">
                    <a class="icon-btn-inline" href="@Url.Action("UserDetails","Admin", new { id = user.Id })" title="View details">View</a>
                    <button type="button"
                            class="icon-btn-inline"
                            data-edit-trigger
                            data-open-modal="editUserModal"
                            data-full-name="@user.FullName"
                            data-email="@user.Email"
                            data-major="@user.Major"
                            data-status="@user.Status"
                            data-progress="@user.Progress">
                        Edit
                    </button>
                    <button type="button" class="icon-btn-inline">Delete</button>
                </td>
            </tr>
        }
        @if (!users.Any())
        {
            <tr>
                <td colspan="9">No interns found.</td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="pagination-bar">
    <span>Showing @users.Count() results</span>
    <div><button class="btn ghost" type="button">Prev</button><button class="pill cyan">1</button><button class="pill">2</button><button class="pill">3</button><button class="btn ghost" type="button">Next</button></div>
</div>

<div class="modal-overlay" id="editUserModal" data-modal role="dialog" aria-modal="true" aria-hidden="true">
    <div class="modal-card">
        <h3>Edit User</h3>
        <form class="edit-user-form" action="@Url.Action("Users","Admin")" method="get">
            <label>Full Name <input type="text" data-edit-field="fullName" /></label>
            <label>Email <input type="email" data-edit-field="email" /></label>
            <label>Major
                <select data-edit-field="major">
                    <option>Web Dev</option>
                    <option>AI</option>
                    <option>Security</option>
                    <option>Data</option>
                </select>
            </label>
            <label>Status
                <select data-edit-field="status">
                    <option>Active</option>
                    <option>Pending</option>
                    <option>Rejected</option>
                </select>
            </label>
            <label>Progress: <span data-progress-output>0%</span>
                <input type="range" min="0" max="100" value="0" data-edit-field="progress" />
            </label>
            <label>Skills <input type="text" data-edit-field="skills" placeholder=".NET, API, Docker, SQL" /></label>
            <div class="modal-actions">
                <button class="btn cyan" type="submit">Save Changes</button>
                <button class="btn ghost" type="button" data-close-modal>Cancel</button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="addUserModal" data-modal role="dialog" aria-modal="true" aria-hidden="true">
    <div class="modal-card modal-card-lg">
        <h3>Add New User</h3>
        <form class="admin-form-grid" action="@Url.Action("CreateUser","Admin")" method="post">
            @Html.AntiForgeryToken()
            <label class="admin-form-field">
                <span>First Name</span>
                <input type="text" name="FirstName" placeholder="Enter first name" required />
            </label>
            <label class="admin-form-field">
                <span>Last Name</span>
                <input type="text" name="LastName" placeholder="Enter last name" required />
            </label>
            <label class="admin-form-field">
                <span>Email</span>
                <input type="email" name="Email" placeholder="name@university.edu" required />
            </label>
            <label class="admin-form-field">
                <span>Password</span>
                <input type="password" name="Password" placeholder="Create password" minlength="8" required />
            </label>
            <label class="admin-form-field">
                <span>Major</span>
                <select name="Major">
                    <option value="">Select major</option>
                    <option>Web Dev</option>
                    <option>AI</option>
                    <option>Security</option>
                    <option>Data</option>
                </select>
            </label>
            <label class="admin-form-field">
                <span>Role</span>
                <select name="Role" required>
                    <option value="">Select role</option>
                    <option>Admin</option>
                    <option>Intern</option>
                </select>
            </label>
            <label class="admin-form-field">
                <span>Status</span>
                <select name="Status" required>
                    <option value="">Select status</option>
                    <option>Active</option>
                    <option>Pending</option>
                    <option>Rejected</option>
                </select>
            </label>
            <div class="modal-actions full">
                <button class="btn cyan" type="submit">Create User</button>
                <button class="btn ghost" type="button" data-close-modal>Cancel</button>
            </div>
        </form>
    </div>
</div>
