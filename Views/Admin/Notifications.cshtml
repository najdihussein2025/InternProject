    <div class="toolbar-actions">
        <form method="post" action="@Url.Action("MarkAllRead", "Admin")">
            @Html.AntiForgeryToken()
            <button class="btn ghost" type="submit" data-mark-all>Mark All as Read</button>
        </form>
        <select><option>All</option><option>Unread</option><option>Applications</option><option>Tasks</option><option>System</option></select>
