@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.PageTitle = "Majors";
}
@* TODO: replace with Model data *@
<section class="page-toolbar">
    <div>
        <h2>Majors</h2>
        <p class="muted-text">Manage major programs, interns, and task planning in one place.</p>
    </div>
    <button class="btn primary-add" type="button" data-open-modal="majorModal"><span class="plus-icon">+</span> Add Major</button>
</section>

<section class="cards-grid major-program-grid">
    <article class="major-program-card">
        <i class="major-top cyan"></i>
        <h3>Web Development</h3>
        <p class="major-duration">Duration: 3 Months</p>
        <div class="major-metrics">
            <div><small>Interns</small><strong>22</strong></div>
            <div><small>Tasks</small><strong>18</strong></div>
        </div>
        <div class="major-card-actions">
            <a class="btn cyan" href="@Url.Action("MajorDetails","Admin", new { id = 1 })">Manage Program</a>
            <a class="btn ghost" href="@Url.Action("MajorInterns","Admin", new { id = 1 })">View Interns</a>
        </div>
    </article>
    <article class="major-program-card">
        <i class="major-top purple"></i>
        <h3>Artificial Intelligence</h3>
        <p class="major-duration">Duration: 3 Months</p>
        <div class="major-metrics">
            <div><small>Interns</small><strong>17</strong></div>
            <div><small>Tasks</small><strong>21</strong></div>
        </div>
        <div class="major-card-actions">
            <a class="btn cyan" href="@Url.Action("MajorDetails","Admin", new { id = 2 })">Manage Program</a>
            <a class="btn ghost" href="@Url.Action("MajorInterns","Admin", new { id = 2 })">View Interns</a>
        </div>
    </article>
    <article class="major-program-card">
        <i class="major-top amber"></i>
        <h3>Cybersecurity</h3>
        <p class="major-duration">Duration: 3 Months</p>
        <div class="major-metrics">
            <div><small>Interns</small><strong>14</strong></div>
            <div><small>Tasks</small><strong>16</strong></div>
        </div>
        <div class="major-card-actions">
            <a class="btn cyan" href="@Url.Action("MajorDetails","Admin", new { id = 3 })">Manage Program</a>
            <a class="btn ghost" href="@Url.Action("MajorInterns","Admin", new { id = 3 })">View Interns</a>
        </div>
    </article>
    <article class="major-program-card">
        <i class="major-top green"></i>
        <h3>Data Engineering</h3>
        <p class="major-duration">Duration: 3 Months</p>
        <div class="major-metrics">
            <div><small>Interns</small><strong>12</strong></div>
            <div><small>Tasks</small><strong>19</strong></div>
        </div>
        <div class="major-card-actions">
            <a class="btn cyan" href="@Url.Action("MajorDetails","Admin", new { id = 4 })">Manage Program</a>
            <a class="btn ghost" href="@Url.Action("MajorInterns","Admin", new { id = 4 })">View Interns</a>
        </div>
    </article>
</section>

<div class="modal-overlay" id="majorModal" data-modal role="dialog" aria-modal="true" aria-hidden="true">
    <div class="modal-card modal-card-lg">
        <h3>Add Major</h3>
        <form class="admin-form-grid" data-ui-only-form>
            <label class="admin-form-field full">
                <span>Major Name</span>
                <input type="text" placeholder="Enter major name" />
            </label>
            <label class="admin-form-field">
                <span>Duration</span>
                <input type="text" value="3 Months" readonly />
            </label>
            <label class="admin-form-field">
                <span>Theme Color</span>
                <select>
                    <option>Cyan</option>
                    <option>Purple</option>
                    <option>Amber</option>
                    <option>Green</option>
                </select>
            </label>
            <label class="admin-form-field full">
                <span>Description</span>
                <textarea rows="3" placeholder="Describe this major program..."></textarea>
            </label>
            <div class="modal-actions full">
                <button class="btn cyan" type="submit">Create Major</button>
                <button class="btn ghost" type="button" data-close-modal>Cancel</button>
            </div>
        </form>
    </div>
</div>
