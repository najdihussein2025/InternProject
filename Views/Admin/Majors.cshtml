@model IEnumerable<InternSystemProject.DTOs.Major.MajorDto>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.PageTitle = "Majors";
}
@{
    var majors = Model ?? Enumerable.Empty<InternSystemProject.DTOs.Major.MajorDto>();
}
<section class="page-toolbar">
    <div>
        <h2>Majors</h2>
        <p class="muted-text">Manage major programs, interns, and task planning in one place.</p>
    </div>
    <button class="btn primary-add" type="button" data-open-modal="majorModal"><span class="plus-icon">+</span> Add Major</button>
</section>

<section class="cards-grid major-program-grid">
    @foreach (var major in majors)
    {
        var theme = string.IsNullOrWhiteSpace(major.ThemeColor) ? "cyan" : major.ThemeColor.ToLowerInvariant();
        <article class="major-program-card">
            <i class="major-top @theme"></i>
            <h3>@major.Name</h3>
            <p class="major-duration">Duration: @major.Duration</p>
            <div class="major-metrics">
                <div><small>Interns</small><strong>@major.InternsCount / @major.MaxInterns</strong></div>
            </div>
            <div class="major-card-actions">
                <a class="btn cyan" href="@Url.Action("MajorDetails","Admin", new { id = major.Id })">Manage Program</a>
                <a class="btn ghost" href="@Url.Action("MajorInterns","Admin", new { id = major.Id })">View Interns</a>
            </div>
        </article>
    }
    @if (!majors.Any())
    {
        <article class="major-program-card">
            <h3>No majors yet</h3>
            <p class="major-duration">Create your first major using the Add Major button.</p>
        </article>
    }
</section>

<div class="modal-overlay" id="majorModal" data-modal role="dialog" aria-modal="true" aria-hidden="true">
    <div class="modal-card modal-card-lg">
        <h3>Add Major</h3>
        <form class="admin-form-grid" action="@Url.Action("CreateMajor","Admin")" method="post">
            @Html.AntiForgeryToken()
            <label class="admin-form-field full">
                <span>Major Name</span>
                <input
                    id="majorName"
                    type="text"
                    name="Name"
                    placeholder="Enter major name"
                    minlength="2"
                    maxlength="80"
                    autocomplete="off"
                    required />
            </label>
            <label class="admin-form-field">
                <span>Duration</span>
                <select id="majorDuration" name="Duration" required>
                    <option value="3 Months" selected>3 Months</option>
                    <option value="4 Months">4 Months</option>
                    <option value="6 Months">6 Months</option>
                </select>
            </label>
            <label class="admin-form-field">
                <span>Theme Color</span>
                <select id="majorThemeColor" name="ThemeColor" required>
                    <option value="Cyan">Cyan</option>
                    <option value="Purple">Purple</option>
                    <option value="Amber">Amber</option>
                    <option value="Green">Green</option>
                </select>
            </label>
            <label class="admin-form-field">
                <span>Max Interns</span>
                <input
                    id="majorMaxInterns"
                    type="number"
                    name="MaxInterns"
                    value="30"
                    min="1"
                    max="1000"
                    required />
            </label>
            <label class="admin-form-field full">
                <span>Description</span>
                <textarea
                    id="majorDescription"
                    rows="3"
                    name="Description"
                    maxlength="600"
                    placeholder="Describe this major program..."></textarea>
            </label>
            <div class="modal-actions full">
                <button class="btn cyan" type="submit">Create Major</button>
                <button class="btn ghost" type="button" data-close-modal>Cancel</button>
            </div>
        </form>
    </div>
</div>
