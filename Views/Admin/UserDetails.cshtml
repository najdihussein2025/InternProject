@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.PageTitle = "User Details";
}
@* TODO: replace with Model data *@
<section class="user-profile-header card">
    <div class="user-profile-main">
        <span class="profile-avatar">SA</span>
        <div>
            <h2>Sara Ahmed</h2>
            <p>sara@internhub.io</p>
            <span class="pill green-soft">Active</span>
        </div>
    </div>
    <button type="button" class="btn cyan" data-edit-trigger data-open-modal="editUserModal" data-full-name="Sara Ahmed" data-email="sara@internhub.io" data-major="Web Dev" data-status="Active" data-progress="78" data-skills=".NET, API, Docker, SQL">Edit User</button>
</section>

<section class="user-info-grid">
    <article class="card info-tile"><p>Major</p><h3>Web Development</h3></article>
    <article class="card info-tile"><p>Join Date</p><h3>2026-01-10</h3></article>
    <article class="card info-tile"><p>Progress</p><h3>78%</h3><div class="progress-line web user-progress"><i style="--w:78%"></i></div></article>
    <article class="card info-tile"><p>Work Mode</p><h3>Hybrid</h3></article>
</section>

<section class="card">
    <h3>Skills</h3>
    <div class="skill-tags">
        <span class="pill cyan-soft">.NET</span>
        <span class="pill cyan-soft">API</span>
        <span class="pill cyan-soft">Docker</span>
        <span class="pill cyan-soft">SQL</span>
    </div>
</section>

<section class="cards-grid user-program-grid">
    <article class="card">
        <h3>Activity / Program</h3>
        <ul class="detail-list">
            <li><span>Current course</span><strong>ASP.NET Core Advanced</strong></li>
            <li><span>Current project</span><strong>Intern Evaluation API</strong></li>
            <li><span>Completed tasks</span><strong>12 of 15</strong></li>
        </ul>
    </article>
    <article class="card">
        <h3>Actions</h3>
        <div class="quick-actions">
            <button type="button" class="btn cyan" data-edit-trigger data-open-modal="editUserModal" data-full-name="Sara Ahmed" data-email="sara@internhub.io" data-major="Web Dev" data-status="Active" data-progress="78" data-skills=".NET, API, Docker, SQL">Edit</button>
            <button type="button" class="btn danger ghost" data-confirm="Delete this user?">Delete</button>
            <a class="btn ghost" href="@Url.Action("Users","Admin")">Back to Users</a>
        </div>
    </article>
</section>

<div class="modal-overlay" id="editUserModal" data-modal role="dialog" aria-modal="true" aria-hidden="true">
    <div class="modal-card">
        <h3>Edit User</h3>
        <form class="edit-user-form" action="@Url.Action("UserDetails","Admin", new { id = ViewBag.UserId ?? 1 })" method="get">
            <label>Full Name <input type="text" data-edit-field="fullName" /></label>
            <label>Email <input type="email" data-edit-field="email" /></label>
            <label>Major
                <select data-edit-field="major">
                    <option>Web Dev</option>
                    <option>AI</option>
                    <option>Security</option>
                    <option>Data</option>
                </select>
            </label>
            <label>Status
                <select data-edit-field="status">
                    <option>Active</option>
                    <option>Pending</option>
                    <option>Rejected</option>
                </select>
            </label>
            <label>Progress: <span data-progress-output>0%</span>
                <input type="range" min="0" max="100" value="0" data-edit-field="progress" />
            </label>
            <label>Skills <input type="text" data-edit-field="skills" placeholder=".NET, API, Docker, SQL" /></label>
            <div class="modal-actions">
                <button class="btn cyan" type="submit">Save Changes</button>
                <button class="btn ghost" type="button" data-close-modal>Cancel</button>
            </div>
        </form>
    </div>
</div>
