@model InternSystemProject.Dtos.Application.CreateApplicationDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Internship Application";
}
<link rel="stylesheet" href="~/css/student.css" asp-append-version="true" />

<section class="student-app-wrap" style="margin-top:2.5rem;">
    <form asp-controller="Application" asp-action="Submit" method="post" class="student-app-card student-panel">
        @Html.AntiForgeryToken()

        <div class="student-app-header">
            <h2>Apply for Internship</h2>
            <p>Complete the form to start your internship journey</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 1rem;"></div>

        <div class="onboarding-steps">
            <span class="active">Step 1: Apply</span>
            <span>Step 2: Review</span>
            <span>Step 3: Start Internship</span>
        </div>

        <div class="student-app-grid">
            <div>
                <label asp-for="University">University <span class="required">*</span></label>
                <input asp-for="University" type="text" placeholder="e.g. Beirut University" />
                <span asp-validation-for="University" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="GraduationYear">Graduation Year <span class="required">*</span></label>
                <input asp-for="GraduationYear" type="number" placeholder="e.g. 2025" />
                <span asp-validation-for="GraduationYear" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="AppliedMajorId">Major <span class="required">*</span></label>
                <select asp-for="AppliedMajorId" required>
                    <option value="">-- Select Major --</option>
                    @foreach (var major in ViewBag.Majors)
                    {
                        <option value="@major.Id">@major.Name</option>
                    }
                </select>
                <span asp-validation-for="AppliedMajorId" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Skills">Skills <span class="required">*</span></label>
                <input asp-for="Skills" type="text" placeholder="e.g. .NET, API, Docker" />
                <span asp-validation-for="Skills" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="GitHubUrl">Project URL (GitHub / Portfolio)</label>
                <input asp-for="GitHubUrl" type="url" placeholder="https://github.com/username/project" />
                <span asp-validation-for="GitHubUrl" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="CoverNote">Cover Note</label>
                <textarea asp-for="CoverNote" rows="4" placeholder="Tell us why you're interested..."></textarea>
                <span asp-validation-for="CoverNote" class="text-danger"></span>
            </div>
        </div>

        <p class="student-app-note">Your application will be reviewed by admin before access is granted.</p>
        <button class="student-btn primary student-app-submit" type="submit">Submit Application</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/student.js" asp-append-version="true"></script>
}