@model InternSystemProject.DTOs.User.LoginDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Login";
}
<link rel="stylesheet" href="~/css/auth.css" />

<section class="auth-page">
    <div class="auth-split">
        <aside class="auth-brand-panel">
            <div class="auth-orb orb-a"></div>
            <div class="auth-orb orb-b"></div>
            <div class="auth-brand-top">
                <div class="auth-logo">
                    <span class="auth-logo-box">IH</span>
                    <h2>InternHub</h2>
                </div>
                <p class="auth-tagline">Intern Management, Simplified.</p>
            </div>

            <article class="visual-card">
                <p class="visual-head">Live Cohort Snapshot</p>
                <div class="visual-row">
                    <span class="avatar">SA</span>
                    <div class="row-copy">
                        <strong>Sara Ahmed</strong>
                        <small>API onboarding checklist</small>
                    </div>
                    <span class="pill done">Done</span>
                </div>
                <div class="bar"><span style="width: 92%"></span></div>

                <div class="visual-row">
                    <span class="avatar">DV</span>
                    <div class="row-copy">
                        <strong>Dev Verma</strong>
                        <small>Auth middleware tests</small>
                    </div>
                    <span class="pill prog">In Progress</span>
                </div>
                <div class="bar"><span style="width: 66%"></span></div>

                <div class="visual-row">
                    <span class="avatar">LT</span>
                    <div class="row-copy">
                        <strong>Lena Torres</strong>
                        <small>Weekly report export</small>
                    </div>
                    <span class="pill rev">Review</span>
                </div>
                <div class="bar"><span style="width: 48%"></span></div>
            </article>

            <div class="auth-quote">
                <p>"The platform that helped us manage 40 interns without losing our minds."</p>
                <small>- Rami T., Engineering Lead at TechNova</small>
            </div>
        </aside>

        <section class="auth-form-panel">
            <a class="mobile-auth-logo" asp-controller="Home" asp-action="Index"><span>IH</span>InternHub</a>

            <div class="auth-form-wrap">
                <p class="section-label">WELCOME BACK</p>
                <h1>Sign in to InternHub</h1>
                <p class="auth-subtext">Enter your credentials to access your dashboard.</p>

                @if (TempData["Success"] != null)
                {
                    <div class="alert-success">@TempData["Success"]</div>
                }

                <form asp-action="Login" asp-controller="Auth" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="field-error"></div>
                    <div class="field">
                        <label class="form-label">EMAIL ADDRESS</label>
                        <input asp-for="Email" class="form-input" type="email" placeholder="sara@yourcompany.com" autocomplete="email" />
                        <span asp-validation-for="Email" class="field-error"></span>
                    </div>

                    <div class="field">
                        <label class="form-label">PASSWORD</label>
                        <div class="input-with-icon">
                            <input asp-for="Password" class="form-input password-input" type="password" autocomplete="current-password" />
                            <button type="button" class="toggle-password" aria-label="Toggle password visibility">
                                <span class="eye-icon" data-eye></span>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="field-error"></span>
                    </div>

                    <div class="row-between">
                        <label class="checkbox-wrap">
                            <input name="rememberMe" type="checkbox" />
                            <span>Remember me</span>
                        </label>
                    </div>

                    <button type="submit" class="btn-submit" data-loading-text="Signing in...">
                        <span>Sign In -></span>
                    </button>

                    <div class="divider"><span>or continue with</span></div>

                    <div class="sso-row">
                        <button type="button" class="sso-btn">
                            <span class="sso-icon">G</span>
                            <span>Google</span>
                        </button>
                        <button type="button" class="sso-btn">
                            <span class="sso-icon ms">■</span>
                            <span>Microsoft</span>
                        </button>
                    </div>
                </form>

                <p class="switch-copy">
                    Don't have an account?
                    <a asp-controller="Auth" asp-action="Register">Create one free -></a>
                </p>
                <p class="security-note">Your data is encrypted and never shared.</p>
            </div>
        </section>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
