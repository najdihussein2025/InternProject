@{
    Layout = null;
    ViewData["Title"] = "InternHub | Contact Us";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=JetBrains+Mono:wght@400;600&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/contact.css" />
</head>
<body>
    <nav class="top-nav">
        <div class="container nav-shell">
            <a href="/Home/Index" class="brand"><span class="brand-icon">▣</span>InternHub</a>
            <div class="nav-links">
                <a href="/Home/Index">Home</a>
                <a href="/Home/About">About Us</a>
                <a class="active" href="/Home/Contact">Contact Us</a>
            </div>
            <div class="actions">
                <a class="btn btn-ghost" asp-controller="Auth" asp-action="Login">Login</a>
                <a class="btn btn-cyan" asp-controller="Auth" asp-action="Register">Register</a>
            </div>
            <button id="menuBtn" class="menu-toggle" aria-label="Open menu" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
        </div>
        <div id="mobileDrawer" class="mobile-drawer container">
            <a href="/Home/Index">Home</a>
            <a href="/Home/About">About Us</a>
            <a class="active" href="/Home/Contact">Contact Us</a>
            <a class="btn btn-ghost" asp-controller="Auth" asp-action="Login">Login</a>
            <a class="btn btn-cyan" asp-controller="Auth" asp-action="Register">Register</a>
        </div>
    </nav>

    <main>
        <section class="hero">
            <div class="hero-orb orb-1"></div>
            <div class="hero-orb orb-2"></div>
            <div class="container hero-inner fade-up">
                <p class="eyebrow">CONTACT US</p>
                <h1>We'd love to <span>hear from you</span></h1>
                <p class="hero-copy">
                    Have a question, a partnership idea, or need support? Our team is ready to help your dev team get the most out of InternHub.
                </p>
            </div>
        </section>

        <section class="contact-wrap">
            <div class="container contact-grid">
                <aside class="info-panel fade-up delay-0">
                    <div class="panel-intro">
                        <h3>Get in touch</h3>
                        <p>Reach out through the form or use any of the channels below. We typically respond within one business day.</p>
                    </div>

                    <div class="contact-cards">
                        <article class="contact-card">
                            <div class="icon-box">✉</div>
                            <div>
                                <p class="meta-label">Email</p>
                                <p class="meta-value">hello@internhub.io</p>
                            </div>
                        </article>
                        <article class="contact-card">
                            <div class="icon-box">📞</div>
                            <div>
                                <p class="meta-label">Phone</p>
                                <p class="meta-value">+1 (800) 555-0192</p>
                            </div>
                        </article>
                        <article class="contact-card">
                            <div class="icon-box">🕐</div>
                            <div>
                                <p class="meta-label">Hours</p>
                                <p class="meta-value">Mon-Fri, 9am - 6pm EST</p>
                            </div>
                        </article>
                        <article class="contact-card">
                            <div class="icon-box">📍</div>
                            <div>
                                <p class="meta-label">Office</p>
                                <p class="meta-value">14 Tech Square, Boston, MA</p>
                            </div>
                        </article>
                    </div>

                    <div class="social-row">
                        <a href="#" aria-label="LinkedIn">in LinkedIn</a>
                        <a href="#" aria-label="Twitter">X Twitter</a>
                        <a href="#" aria-label="GitHub">⌥ GitHub</a>
                    </div>
                </aside>

                <section class="form-card fade-up delay-1">
                    <div id="formContent">
                        <header class="form-header">
                            <h2>Send us a message</h2>
                            <p>Fill in the form below and a member of our team will get back to you shortly.</p>
                        </header>

                        <form id="contactForm">
                            <div class="row two-col">
                                <div class="field">
                                    <label for="firstName">First Name</label>
                                    <input id="firstName" name="firstName" type="text" required />
                                </div>
                                <div class="field">
                                    <label for="lastName">Last Name</label>
                                    <input id="lastName" name="lastName" type="text" required />
                                </div>
                            </div>

                            <div class="field">
                                <label for="email">Work Email</label>
                                <input id="email" name="email" type="email" placeholder="sara@yourcompany.com" required />
                            </div>

                            <div class="field">
                                <label for="company">Company Name</label>
                                <input id="company" name="company" type="text" placeholder="TechNova Inc." required />
                            </div>

                            <div class="field">
                                <label for="role">Department / Role</label>
                                <select id="role" name="role" required>
                                    <option value="">Select one</option>
                                    <option>Engineering Lead</option>
                                    <option>HR Manager</option>
                                    <option>CTO / VP Engineering</option>
                                    <option>Recruiter</option>
                                    <option>Other</option>
                                </select>
                            </div>

                            <div class="field">
                                <label>Topic</label>
                                <div class="topic-pills" id="topicPills">
                                    <button type="button" class="topic-pill selected">General Inquiry</button>
                                    <button type="button" class="topic-pill">Product Demo</button>
                                    <button type="button" class="topic-pill">Technical Support</button>
                                    <button type="button" class="topic-pill">Partnership</button>
                                    <button type="button" class="topic-pill">Pricing</button>
                                    <button type="button" class="topic-pill">Bug Report</button>
                                </div>
                            </div>

                            <div class="field">
                                <label for="message">Message</label>
                                <textarea id="message" name="message" maxlength="500" placeholder="Tell us how we can help your team..." required></textarea>
                                <p class="char-count"><span id="charCount">0</span> / 500</p>
                            </div>

                            <button type="submit" class="btn submit-btn">Send Message →</button>
                        </form>
                    </div>

                    <div id="successMsg" class="success-msg" hidden>
                        <div class="success-icon">✓</div>
                        <h3>Message sent!</h3>
                        <p>Thanks for reaching out. A member of our team will get back to you at your work email within one business day.</p>
                    </div>
                </section>
            </div>
        </section>

        <section class="container map-strip fade-up">
            <div class="pin-wrap">
                <div class="pin-circle">📍</div>
                <p class="map-title">InternHub HQ</p>
                <p class="map-sub">14 Tech Square, Boston, MA 02139</p>
            </div>
        </section>
    </main>

    <script src="/js/contact.js"></script>
</body>
</html>
