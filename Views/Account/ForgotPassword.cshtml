@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Forgot Password";
}
<link rel="stylesheet" href="~/css/auth.css" />

<section class="auth-simple">
    <div class="auth-simple-card">
        <p class="section-label">ACCOUNT SUPPORT</p>
        <h1>Forgot password</h1>
        <p>Please contact your administrator to reset your account password.</p>
        <a class="btn-submit" href="@Url.Action("Login", "Account")"><span>Back to Login</span></a>
    </div>
</section>
